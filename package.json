{
  "name": "handsoff-hackathon",
  "version": "0.0.0",
  "private": true,
  "description": "Mock monorepo with Vite + React frontend and Fastify backend, deployed on Vercel.",
  "scripts": {
    "dev:web": "pnpm --filter @handsoff/web dev",
    "dev:api": "pnpm --filter @handsoff/api dev",
    "build:web": "pnpm --filter @handsoff/web build",
    "build:api": "pnpm --filter @handsoff/api build",
    "build": "pnpm build:api && pnpm build:web",
    "preview:web": "pnpm --filter @handsoff/web preview",
    "lint": "pnpm -r --if-present lint"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  }
}
