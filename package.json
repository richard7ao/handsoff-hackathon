{
  "name": "handsoff-hackathon",
  "version": "0.0.0",
  "private": true,
  "description": "Mock monorepo with Vite + React frontend and Fastify backend, deployed on Vercel.",
  "scripts": {
    "dev:frontend": "pnpm --filter @handsoff/frontend dev",
    "dev:backend": "pnpm --filter @handsoff/backend dev",
    "build:frontend": "pnpm --filter @handsoff/frontend build",
    "build:backend": "pnpm --filter @handsoff/backend build",
    "build": "pnpm build:backend && pnpm build:frontend",
    "preview:frontend": "pnpm --filter @handsoff/frontend preview",
    "lint": "pnpm -r --if-present lint"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  }
}
