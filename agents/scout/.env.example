# Scout agent — required environment variables.
# Copy to ~/.hermes/.env (Hermes loads it) — do NOT commit real values.

# Supabase (Person A owns the project; service-role key bypasses RLS, server-side only)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role key>

# Tavily (search/scrape) — get a key at https://app.tavily.com
TAVILY_API_KEY=tvly-<your key>
