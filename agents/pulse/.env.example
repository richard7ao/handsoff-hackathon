# Pulse agent — Reddit credentials (Person C owns these).
# Register a Reddit "script" app at https://www.reddit.com/prefs/apps
# Copy these into ~/.hermes/.env — do NOT commit real values.

REDDIT_CLIENT_ID=<app client id>
REDDIT_CLIENT_SECRET=<app client secret>
REDDIT_USERNAME=<bot account username>
REDDIT_PASSWORD=<bot account password>
REDDIT_USER_AGENT=signal-pulse/0.1 by u/<username>
