# Copy to .env and fill in real values (.env is gitignored).

# Gemini — powers POST /api/chat (server-side only, never expose to the client)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Supabase (optional; not used by the stateless chat yet)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
